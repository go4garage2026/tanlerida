# =============================================================================
# TANLERIDA - Root .gitignore
# =============================================================================

# =============================================================================
# Dependencies
# =============================================================================
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
package-lock.json
yarn.lock
pnpm-lock.yaml

# =============================================================================
# Build Outputs
# =============================================================================
dist/
build/
.next/
out/
*.tsbuildinfo

# =============================================================================
# Environment Variables
# =============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# =============================================================================
# IDE & Editor
# =============================================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# =============================================================================
# Testing
# =============================================================================
coverage/
.nyc_output/
*.lcov

# =============================================================================
# Logs
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# =============================================================================
# OS Generated
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================================================
# Temporary Files
# =============================================================================
*.tmp
*.temp
.cache/
tmp/
temp/

# =============================================================================
# Deployment
# =============================================================================
.vercel
.netlify

# =============================================================================
# Database
# =============================================================================
*.sqlite
*.sqlite3
*.db

# =============================================================================
# Backup Files
# =============================================================================
*.bak
*.backup
*.old

# =============================================================================
# Miscellaneous
# =============================================================================
*.pem
*.cert
*.key
.secret

# =============================================================================
# Project Specific
# =============================================================================
# Snapshots are kept but can be ignored if needed
# .snapshots/

# Qodo configuration is kept
# .qodo/

# Large media files (should use CDN in production)
*.mp4
*.mov
*.avi
*.wmv

# Large image files (unoptimized)
*.psd
*.ai
*.sketch

# Firebase
.firebase/

# Local AI workspace settings
.claude/settings.local.json
