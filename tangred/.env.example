# =============================================================================
# TANLERIDA - Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control!
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://username:password@localhost:5432/tangred_db"

# =============================================================================
# AUTHENTICATION (NextAuth.js v5)
# =============================================================================
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET="your-super-secret-auth-key-minimum-32-characters-long"

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# =============================================================================
# AI SERVICES
# =============================================================================
# GitHub Models (https://github.com/marketplace/models)
# Used for: All AI features when Gemini/Claude are not configured
# Generate a token at: https://github.com/settings/tokens (needs "models" scope)
GITHUB_TOKEN=""

# Google Gemini API (https://ai.google.dev/) — optional if using GitHub Models
# Used for: Vision analysis of user photos
GOOGLE_GEMINI_API_KEY="your-gemini-api-key"

# Anthropic Claude API (https://console.anthropic.com/) — optional if using GitHub Models
# Used for: Natural language recommendations
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"

# Pinecone Vector Database (https://app.pinecone.io/)
# Used for: Semantic product search
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_INDEX_NAME="tangred-products"
PINECONE_ENVIRONMENT="us-east-1-aws"

# Replicate API (https://replicate.com/)
# Used for: AI image generation
REPLICATE_API_TOKEN="r8_your-replicate-api-token"

# =============================================================================
# FILE STORAGE (Cloudinary)
# =============================================================================
# Cloudinary (https://cloudinary.com/)
# Used for: Product images, user photo uploads
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# =============================================================================
# PAYMENTS (Razorpay)
# =============================================================================
# Razorpay (https://dashboard.razorpay.com/)
# Used for: Payment processing (UPI, Cards, Net Banking)
RAZORPAY_KEY_ID="rzp_test_your-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-secret"

# =============================================================================
# EMAIL (Resend)
# =============================================================================
# Resend (https://resend.com/)
# Used for: Transactional emails
RESEND_API_KEY="re_your-resend-api-key"
FROM_EMAIL="Tangred <noreply@tangred.com>"
REPLY_TO_EMAIL="support@tangred.com"

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Public URL (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Tan Lerida pricing (in INR)
NEXT_PUBLIC_TAN_LEIDA_PRICE="99"
NEXT_PUBLIC_TAN_LEIDA_GST_PERCENT="18"

# Feature flags
NEXT_PUBLIC_ENABLE_AI_FEATURES="true"
NEXT_PUBLIC_ENABLE_PAYMENTS="true"
NEXT_PUBLIC_ENABLE_ANALYTICS="false"

# =============================================================================
# OPTIONAL: Third-party Services
# =============================================================================
# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Sentry (optional - error tracking)
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# Redis (optional - for caching)
# REDIS_URL="redis://localhost:6379"

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================
# Skip build-time type checking (faster builds during dev)
# NEXT_TELEMETRY_DISABLED=1

# Debug mode
# DEBUG="tangred:*"
